# Copy to .env.local and fill in. Create an app at:
# https://cloud.ouraring.com/oauth/applications
# Register redirect URI exactly, e.g.:
#   http://localhost:3000/api/oura/callback
#   https://your-domain.com/api/oura/callback

OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:3000/api/oura/callback

# Optional: space-separated Oura scopes (default: daily workout)
# OURA_SCOPES=daily workout

# Optional: absolute path to JSON token file (default: .data/oura-tokens.json in project root).
# Serverless hosts have ephemeral filesystem — use a database for real deployments.
