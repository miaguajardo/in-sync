# Copy to .env.local and fill in. Create an app at:
# https://cloud.ouraring.com/oauth/applications
# Register redirect URI exactly, e.g.:
#   http://localhost:3000/api/oura/callback
#   https://your-domain.com/api/oura/callback

OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:3000/api/oura/callback

# Optional: space-separated Oura scopes (default: daily workout)
# OURA_SCOPES=daily workout

# After OAuth, smoke-test v2 calls (last 7 days by default):
#   GET /api/oura/snapshot
# Optional: ?start_date=YYYY-MM-DD&end_date=YYYY-MM-DD (max 31 days)

# Supabase — workouts, Oura links, per-user Oura tokens, Google sign-in (Auth).
# Apply SQL in supabase/migrations/ in the Supabase SQL editor (or CLI).
# Enable Google provider under Authentication > Providers.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role for admin scripts only (not used by the app UI/API paths).
# SUPABASE_SERVICE_ROLE_KEY=
